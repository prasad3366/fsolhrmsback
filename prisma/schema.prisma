generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  role            Role
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  refreshToken    String?
  resetOtp        String?
  resetOtpExpires DateTime?
  assets          Asset[]
  employee        Employee?
}

model Employee {
  id                Int                @id @default(autoincrement())
  userId            Int                @unique
  empCode           String             @unique
  firstName         String
  lastName          String
  department        String
  designation       String
  createdAt         DateTime           @default(now())
  workMode          WorkMode           @default(OFFICE)
  isExperienced     Boolean            @default(false)
  aadharNumber      String?
  addedBy           String?
  age               Int?
  bankAccountNumber String?
  bankName          String?
  city              String?
  currentAddress    String?
  currentExperience Float?
  dateOfBirth       DateTime?
  dateOfExit        DateTime?
  dateOfJoining     DateTime?
  employmentType    EmploymentType?
  gender            Gender?
  ifscCode          String?
  maritalStatus     MaritalStatus?
  panNumber         String?
  permanentAddress  String?
  personalMobile    String?
  pfNumber          String?
  phone             String?
  pincode           String?
  reportingManager  String?
  sourceOfHire      String?
  status            EmployeeStatus     @default(ACTIVE)
  uanNumber         String?
  attendances       Attendance[]
  logs              AttendanceLog[]
  user              User               @relation(fields: [userId], references: [id])
  documents         EmployeeDocument[]
  salaries          EmployeeSalary[]
  leaves            Leave[]
  leaveBalances     LeaveBalance[]
  payrolls          Payroll[]
  wfhRequests       WFHRequest[]
  teamId Int?
  team   Team? @relation("TeamMembers", fields: [teamId], references: [id])
  managedTeam Team[] @relation("TeamManager")
  @@index([teamId])
}

model OfficeLocation {
  id        Int      @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  radius    Float
  createdAt DateTime @default(now())
}

model Attendance {
  id             Int              @id @default(autoincrement())
  employeeId     Int
  date           DateTime
  punchIn        DateTime?
  punchOut       DateTime?
  punchInLat     Float?
  punchInLng     Float?
  punchOutLat    Float?
  punchOutLng    Float?
  totalHours     Float            @default(0)
  overtime       Float            @default(0)
  status         AttendanceStatus @default(PRESENT)
  isAutoClosed   Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  locationStatus LocationStatus?
  employee       Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model AttendanceLog {
  id         Int       @id @default(autoincrement())
  employeeId Int
  type       PunchType
  time       DateTime  @default(now())
  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model WFHRequest {
  id         Int       @id @default(autoincrement())
  employeeId Int
  startDate  DateTime
  endDate    DateTime
  status     WFHStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  reason     String?
  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model LeaveType {
  id              Int            @id @default(autoincrement())
  name            String         @unique
  yearlyQuota     Float
  carryForward    Boolean        @default(false)
  maxCarryLimit   Float?
  monthlyAccrual  Float?
  requiresMedical Boolean?       @default(false)
  leaves          Leave[]
  balances        LeaveBalance[]
}

model LeaveBalance {
  id           Int       @id @default(autoincrement())
  employeeId   Int
  leaveTypeId  Int
  yearStart    Int
  allocated    Float     @default(0)
  used         Float     @default(0)
  carryForward Float     @default(0)
  employee     Employee  @relation(fields: [employeeId], references: [id])
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, yearStart])
}

model Leave {
  id                 Int               @id @default(autoincrement())
  employeeId         Int
  leaveTypeId        Int
  yearStart          Int
  startDate          DateTime
  endDate            DateTime
  durationType       LeaveDurationType @default(FULL_DAY)
  totalDays          Float
  reason             String
  status             LeaveStatus       @default(PENDING)
  remarks            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isEmergency        Boolean           @default(false)
  medicalCertificate String?
  employee           Employee          @relation(fields: [employeeId], references: [id])
  leaveType          LeaveType         @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@index([yearStart])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  description String?
  isOptional  Boolean  @default(false)
  location    String?
  createdAt   DateTime @default(now())

  @@unique([date, location])
  @@index([date])
}

model DocumentType {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  isMandatory    Boolean            @default(false)
  forFresher     Boolean            @default(true)
  forExperienced Boolean            @default(true)
  documents      EmployeeDocument[]
}

model EmployeeDocument {
  id             Int            @id @default(autoincrement())
  employeeId     Int
  documentTypeId Int
  fileName       String
  mimeType       String
  fileData       Bytes
  status         DocumentStatus @default(PENDING)
  remarks        String?
  verifiedBy     Int?
  verifiedAt     DateTime?
  uploadedAt     DateTime       @default(now())
  documentType   DocumentType   @relation(fields: [documentTypeId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])
  

  @@unique([employeeId, documentTypeId])
  @@index([employeeId])
}

model SalaryStructure {
  id                Int              @id @default(autoincrement())
  name              String
  basicPercent      Float            @default(35)
  hraPercent        Float            @default(50)
  pfPercent         Float            @default(12)
  ptAmount          Float            @default(200)
  healthInsurance   Float            @default(0)
  createdAt         DateTime         @default(now())
  conveyancePercent Float            @default(15)
  salaries          EmployeeSalary[]
}

model EmployeeSalary {
  id            Int             @id @default(autoincrement())
  employeeId    Int
  structureId   Int
  annualCTC     Float
  monthlyCTC    Float
  effectiveFrom DateTime
  employee      Employee        @relation(fields: [employeeId], references: [id])
  structure     SalaryStructure @relation(fields: [structureId], references: [id])
  payrolls      Payroll[]

  @@index([employeeId])
}

model Payroll {
  id               Int                 @id @default(autoincrement())
  employeeId       Int
  salaryId         Int
  month            Int
  year             Int
  workingDays      Int
  presentDays      Float
  lopDays          Float
  /// Earnings
  basic            Float
  hra              Float
  /// Deductions
  pf               Float
  pt               Float
  deductions       Float
  /// Totals
  grossSalary      Float
  netSalary        Float
  status           PayrollStatus       @default(DRAFT)
  createdAt        DateTime            @default(now())
  leaveDeduction   Float               @default(0)
  otherAllowance   Float               @default(0)
  specialAllowance Float               @default(0)
  employee         Employee            @relation(fields: [employeeId], references: [id])
  salary           EmployeeSalary      @relation(fields: [salaryId], references: [id])
  others           PayrollAdjustment[]

  @@unique([employeeId, month, year])
}

model PayrollAdjustment {
  id        Int            @id @default(autoincrement())
  payrollId Int
  name      String
  type      AdjustmentType
  amount    Float
  createdAt DateTime       @default(now())
  payroll   Payroll        @relation(fields: [payrollId], references: [id])
}

model Asset {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  assignedTo  Int?
  assignedAt  DateTime?
  createdAt   DateTime  @default(now())
  returnedAt  DateTime?
  status      String    @default("ASSIGNED")
  user        User?     @relation(fields: [assignedTo], references: [id])
}
model Team {
  id        Int      @id @default(autoincrement())
  name      String

  managerId Int
  manager   Employee @relation("TeamManager", fields: [managerId], references: [id])

  members   Employee[] @relation("TeamMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([managerId])
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum MaritalStatus {
  MARRIED
  UNMARRIED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
}

enum PunchType {
  IN
  OUT
}

enum LocationStatus {
  OFFICE
  OUTSIDE
  WFH
}

enum WorkMode {
  OFFICE
  WFH
  REMOTE
}

enum WFHStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveDurationType {
  FULL_DAY
  HALF_DAY_FIRST
  HALF_DAY_SECOND
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
}

enum AdjustmentType {
  ALLOWANCE
  DEDUCTION
}
